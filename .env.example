# ==========================================
# Telegram Bot Configuration
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# ==========================================
# Database Configuration
# ==========================================
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///data/db.sqlite

# For PostgreSQL (alternative)
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/paper_airplane_bot

# For MongoDB (alternative)
# DATABASE_TYPE=mongodb
# DATABASE_URL=mongodb://user:password@localhost:27017/paper_airplane_bot

# ==========================================
# AI & Analytics Configuration
# ==========================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
ENABLE_AI_ANALYSIS=true

# Computer Vision
OPENCV_ENABLED=true
OPENCV_CONFIDENCE_THRESHOLD=0.7

# ==========================================
# Feature Flags
# ==========================================
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_LEADERBOARD=true
ENABLE_ACHIEVEMENTS=true
ENABLE_IMAGE_ANALYSIS=true
ENABLE_DATA_BACKUP=true

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==========================================
# Application Configuration
# ==========================================
APP_NAME=Paper Airplane Bot
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
DEBUG=true

# ==========================================
# Timezone & Localization
# ==========================================
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=zh_CN
SUPPORTED_LANGUAGES=zh_CN,en_US,ja_JP

# ==========================================
# API Configuration
# ==========================================
API_RATE_LIMIT=100
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# ==========================================
# Backup & Maintenance
# ==========================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_DIR=data/backups
BACKUP_RETENTION_DAYS=30

# ==========================================
# Security
# ==========================================
SECRET_KEY=your-secret-key-for-encryption
PASSWORD_HASH_ALGORITHM=bcrypt

# ==========================================
# Notification Settings
# ==========================================
NOTIFICATION_ON_JOIN=true
NOTIFICATION_ON_ACHIEVEMENT=true
NOTIFICATION_ON_COMPETITION_START=true
NOTIFICATION_ON_LEADERBOARD_UPDATE=true
